{
    "name": "vortexhost/site",
    "description": "Site institucional e comercial da VortexHost em PHP com Composer.",
    "type": "project",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "serve": "php -S localhost:8000 -t public",
        "setup": "php scripts/setup.php"
    }
}