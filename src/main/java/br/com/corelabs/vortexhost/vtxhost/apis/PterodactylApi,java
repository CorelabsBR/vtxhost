package com.corelabs.ptero;

import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;
import org.springframework.http.*;
import java.util.*;

@Service
public class PterodactylApi {

    private final String PANEL_URL = "https://painel.corelabs.dev.br";
    private final String API_KEY = "ptla_WKzsoBJugGI9xZ0qI0E0MCBw6fXHRXJXQTW7oxOpi1J";

    private final RestTemplate rest = new RestTemplate();

    private HttpHeaders getHeaders() {
        HttpHeaders headers = new HttpHeaders();
        headers.set("Authorization", "Bearer " + API_KEY);
        headers.setContentType(MediaType.APPLICATION_JSON);
        headers.setAccept(List.of(MediaType.APPLICATION_JSON));
        return headers;
    }

    // =========================
    // CRIAR USUÁRIO
    // =========================
    public Integer createUser(String username, String email, String firstName, String lastName, String password) {

        String url = PANEL_URL + "/api/application/users";

        Map<String, Object> body = new HashMap<>();
        body.put("username", username);
        body.put("email", email);
        body.put("first_name", firstName);
        body.put("last_name", lastName);
        body.put("password", password);

        HttpEntity<Map<String, Object>> request = new HttpEntity<>(body, getHeaders());

        ResponseEntity<Map> response = rest.postForEntity(url, request, Map.class);

        Map data = (Map) response.getBody().get("attributes");
        return (Integer) data.get("id");
    }

    // =========================
    // PEGAR ALLOCATION LIVRE
    // =========================
    public Integer getFreeAllocation(int nodeId) {

        String url = PANEL_URL + "/api/application/nodes/" + nodeId + "/allocations";

        HttpEntity<Void> request = new HttpEntity<>(getHeaders());
        ResponseEntity<Map> response = rest.exchange(url, HttpMethod.GET, request, Map.class);

        List<Map> data = (List<Map>) response.getBody().get("data");

        for (Map item : data) {
            Map attr = (Map) item.get("attributes");
            if (!(Boolean) attr.get("assigned")) {
                return (Integer) attr.get("id");
            }
        }

        throw new RuntimeException("Sem allocation livre, товарищ");
    }

    // =========================
    // CRIAR SERVER
    // =========================
    public void createServer(
            String name,
            int userId,
            int eggId,
            int nodeId,
            int allocationId,
            int ram,
            int disk,
            Integer cpu
    ) {

        String url = PANEL_URL + "/api/application/servers";

        Map<String, Object> body = new HashMap<>();

        body.put("name", name);
        body.put("user", userId);
        body.put("egg", eggId);

        body.put("docker_image", "ghcr.io/pterodactyl/yolks:java_21");

        body.put("startup", "java -Xms128M -Xmx{{SERVER_MEMORY}}M -jar server.jar");

        body.put("environment", new HashMap<>());

        Map<String, Object> limits = new HashMap<>();
        limits.put("memory", ram);
        limits.put("swap", 0);
        limits.put("disk", disk);
        limits.put("io", 500);
        limits.put("cpu", cpu == null ? 0 : cpu);

        body.put("limits", limits);

        Map<String, Object> featureLimits = new HashMap<>();
        featureLimits.put("databases", 0);
        featureLimits.put("allocations", 1);
        featureLimits.put("backups", 0);

        body.put("feature_limits", featureLimits);

        Map<String, Object> deploy = new HashMap<>();
        deploy.put("locations", List.of(nodeId));
        deploy.put("dedicated_ip", false);
        deploy.put("port_range", new ArrayList<>());

        body.put("deploy", deploy);

        Map<String, Object> allocation = new HashMap<>();
        allocation.put("default", allocationId);

        body.put("allocation", allocation);

        HttpEntity<Map<String, Object>> request = new HttpEntity<>(body, getHeaders());

        rest.postForEntity(url, request, Map.class);
    }
}